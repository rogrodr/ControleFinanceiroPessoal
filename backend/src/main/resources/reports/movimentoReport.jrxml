	<property name="com.jaspersoft.studio.data.sql.tables" value="bW92aW1lbnRvcyBBUyAsMTg0LDY2LDY2NTU2OTBmLTg0MTMtNDY0OS05YTMzLThhNzJmMjdhMTc1MDs="/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="ControleFinanceiro"/>
	
	<parameter name="userId" class="java.lang.Long">
		<defaultValueExpression><![CDATA[1L]]></defaultValueExpression>
	</parameter>
	
	<parameter name="dataInicio" class="java.sql.Date">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	
	<parameter name="dataFim" class="java.sql.Date">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	
	<parameter name="tipo" class="java.lang.String">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	
	<parameter name="PERIODO" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todos os períodos"]]></defaultValueExpression>
	</parameter>
	
	<parameter name="DATA_GERACAO" class="java.lang.String">
		<defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM/yyyy").format(new java.util.Date())]]></defaultValueExpression>
	</parameter>
	
	<queryString language="SQL"><![CDATA[
		SELECT 
			category,
			date,
			description,
			status_pagamento,
			tipo,
			valor
		FROM movimentos
		WHERE user_id = $P{userId}
			AND ($P{dataInicio} IS NULL OR date >= $P{dataInicio})
			AND ($P{dataFim} IS NULL OR date <= $P{dataFim})
			AND ($P{tipo} IS NULL OR $P{tipo} = '' OR tipo = $P{tipo})
		ORDER BY date DESC
	]]></queryString>
	
	<field name="category" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="category"/>
		<property name="com.jaspersoft.studio.field.label" value="category"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="movimentos"/>
	</field>
	<field name="date" class="java.sql.Date">
		<property name="com.jaspersoft.studio.field.name" value="date"/>
		<property name="com.jaspersoft.studio.field.label" value="date"/>
